+        Map<String, Object> record = builder.buildRecordFromFields(
+                List.of(parent), Map.of("addr.msisdn", "905321234567"));
+
+        Map<String, Object> addr = (Map<String, Object>) record.get("addr");
+        assertEquals("\"905321234567\"", addr.get("msisdn"));
+    }
